<controls:MetroWindow x:Class="FindRomCover.AboutWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="About"
                      Width="450"
                      Height="400"
                      ResizeMode="NoResize"
                      WindowStartupLocation="CenterScreen"
                      ToolTip="About FindRomCover">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="10"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            ToolTip="Application logo">
            <Image
                Width="150"
                Height="150"
                Source="pack://application:,,,/images/logo.png"
                ToolTip="FindRomCover logo" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10"
                    ToolTip="Application information">
            <TextBlock FontWeight="Bold" Text="FindRomCover"
                       ToolTip="Application name" />
            <TextBlock Text="Organize your ROM images collection"
                       ToolTip="Application description" />
            <TextBlock Name="AppVersionTextBlock" Margin="0,10,0,0" Text=""
                       ToolTip="Current application version number" />
            <TextBlock Margin="0,10,0,0"
                       ToolTip="Visit the developer's website">
                <Hyperlink NavigateUri="https://www.purelogiccode.com" RequestNavigate="Hyperlink_RequestNavigate">https://www.purelogiccode.com</Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,10,0,10"
                       ToolTip="View the source code on GitHub">
                <Hyperlink NavigateUri="https://github.com/drpetersonfernandes/FindRomCover" RequestNavigate="Hyperlink_RequestNavigate">https://github.com/drpetersonfernandes/FindRomCover</Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="10"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            ToolTip="Window controls">
            <Button
                Width="120"
                Margin="10,0,0,0"
                Click="CloseButton_Click"
                Content="Close"
                ToolTip="Close the About window" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
