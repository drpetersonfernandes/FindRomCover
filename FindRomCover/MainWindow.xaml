<controls:MetroWindow x:Class="FindRomCover.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      mc:Ignorable="d"
                      Title="Find ROM Cover"
                      MinWidth="900"
                      MinHeight="600"
                      WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- DataTemplate for image cells -->
        <DataTemplate x:Key="ImageCellTemplate">
            <Button Style="{StaticResource ImageSuggestionButtonStyle}"
                    Click="ImageCell_Click"
                    ContextMenuOpening="Image_ContextMenuOpening"
                    AutomationProperties.Name="{Binding ImageName, StringFormat='Image: {0}'}"
                    AutomationProperties.HelpText="{Binding SimilarityScore, StringFormat='Similarity: {0:F2}%'}"
                    ToolTip="{Binding ImageName, StringFormat='Click to assign: {0}'}">
                <StackPanel>
                        <Image
                        Width="{Binding Path=Settings.ImageWidth, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=200}"
                        Height="{Binding Path=Settings.ImageHeight, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=200}"
                        Source="{Binding DisplayImage, FallbackValue={x:Null}}" />
                    <TextBlock HorizontalAlignment="Center" Text="{Binding ImageName, FallbackValue=''}" FontWeight="Bold"
                               Margin="0,5,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding ImageName, FallbackValue=''}"/>
                    <TextBlock HorizontalAlignment="Center"
                               Text="{Binding SimilarityScore, StringFormat={}{0:F2}%, FallbackValue='0.00%'}" FontWeight="Bold"
                               ToolTip="{Binding SimilarityScore, StringFormat='Similarity score: {0:F2}%'}" />
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Keyboard shortcuts for common actions -->
        <KeyBinding Key="F5" Command="{Binding CheckForMissingImagesCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ExitCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Name="MainMenu"
              AutomationProperties.Name="Main Menu"
              AutomationProperties.HelpText="Application menu with settings and options">
            <!-- Menu Items remain the same, but placed here for context -->
            <MenuItem x:Name="MenuSimilarityAlgorithms" Header="Set Similarity Algorithm"
                      ToolTip="Choose the algorithm used to compare ROM names with image filenames">
                <MenuItem x:Name="MenuAlgorithmJaccard" Click="SetSimilarityAlgorithm_Click"
                          Header="Jaccard Similarity" IsCheckable="True"
                          ToolTip="Use Jaccard Similarity to compare names based on shared character sets" />
                <MenuItem x:Name="MenuAlgorithmJaroWinkler" Click="SetSimilarityAlgorithm_Click"
                          Header="Jaro-Winkler Distance" IsCheckable="True"
                          ToolTip="Use Jaro-Winkler Distance to compare names with prefix weighting" />
                <MenuItem x:Name="MenuAlgorithmLevenshtein" Click="SetSimilarityAlgorithm_Click"
                          Header="Levenshtein Distance" IsCheckable="True"
                          ToolTip="Use Levenshtein Distance to compare names based on edit operations" />
            </MenuItem>
            <MenuItem x:Name="MySimilarityMenu" Header="Set Similarity Threshold"
                      ToolTip="Set the minimum similarity percentage required for matches">
                <MenuItem x:Name="Menu10" Click="SetSimilarityThreshold_Click" Header="10%" IsCheckable="True"
                          ToolTip="Only show matches with at least 10% similarity" />
                <MenuItem x:Name="Menu20" Click="SetSimilarityThreshold_Click" Header="20%" IsCheckable="True"
                          ToolTip="Only show matches with at least 20% similarity" />
                <MenuItem x:Name="Menu30" Click="SetSimilarityThreshold_Click" Header="30%" IsCheckable="True"
                          ToolTip="Only show matches with at least 30% similarity" />
                <MenuItem x:Name="Menu40" Click="SetSimilarityThreshold_Click" Header="40%" IsCheckable="True"
                          ToolTip="Only show matches with at least 40% similarity" />
                <MenuItem x:Name="Menu50" Click="SetSimilarityThreshold_Click" Header="50%" IsCheckable="True"
                          ToolTip="Only show matches with at least 50% similarity" />
                <MenuItem x:Name="Menu60" Click="SetSimilarityThreshold_Click" Header="60%" IsCheckable="True"
                          ToolTip="Only show matches with at least 60% similarity" />
                <MenuItem x:Name="Menu70" Click="SetSimilarityThreshold_Click" Header="70%" IsCheckable="True"
                          ToolTip="Only show matches with at least 70% similarity" />
                <MenuItem x:Name="Menu80" Click="SetSimilarityThreshold_Click" Header="80%" IsCheckable="True"
                          ToolTip="Only show matches with at least 80% similarity" />
                <MenuItem x:Name="Menu90" Click="SetSimilarityThreshold_Click" Header="90%" IsCheckable="True"
                          ToolTip="Only show matches with at least 90% similarity" />
            </MenuItem>
            <MenuItem x:Name="ImageSizeMenu" Header="Set Thumbnail Size"
                      ToolTip="Set the display size for image thumbnails">
                <MenuItem x:Name="Thumbnail100" Click="SetThumbnailSize_Click" Header="100 pixels" IsCheckable="True" Tag="100"
                          ToolTip="Display thumbnails at 100 pixels" />
                <MenuItem x:Name="Thumbnail150" Click="SetThumbnailSize_Click" Header="150 pixels" IsCheckable="True" Tag="150"
                          ToolTip="Display thumbnails at 150 pixels" />
                <MenuItem x:Name="Thumbnail200" Click="SetThumbnailSize_Click" Header="200 pixels" IsCheckable="True" Tag="200"
                          ToolTip="Display thumbnails at 200 pixels" />
                <MenuItem x:Name="Thumbnail250" Click="SetThumbnailSize_Click" Header="250 pixels" IsCheckable="True" Tag="250"
                          ToolTip="Display thumbnails at 250 pixels" />
                <MenuItem x:Name="Thumbnail300" Click="SetThumbnailSize_Click" Header="300 pixels" IsCheckable="True" Tag="300"
                          ToolTip="Display thumbnails at 300 pixels" />
                <MenuItem x:Name="Thumbnail350" Click="SetThumbnailSize_Click" Header="350 pixels" IsCheckable="True" Tag="350"
                          ToolTip="Display thumbnails at 350 pixels" />
                <MenuItem x:Name="Thumbnail400" Click="SetThumbnailSize_Click" Header="400 pixels" IsCheckable="True" Tag="400"
                          ToolTip="Display thumbnails at 400 pixels" />
                <MenuItem x:Name="Thumbnail450" Click="SetThumbnailSize_Click" Header="450 pixels" IsCheckable="True" Tag="450"
                          ToolTip="Display thumbnails at 450 pixels" />
                <MenuItem x:Name="Thumbnail500" Click="SetThumbnailSize_Click" Header="500 pixels" IsCheckable="True" Tag="500"
                          ToolTip="Display thumbnails at 500 pixels" />
            </MenuItem>
            <MenuItem Header="Settings" ToolTip="Application settings">
                <MenuItem x:Name="MenuUseMameDescription" Header="Use MAME Description" IsCheckable="True" Click="MenuUseMameDescription_ClickAsync"
                          ToolTip="Use MAME database descriptions instead of ROM filenames for matching">
                </MenuItem>
                <MenuItem Click="EditExtensions_Click" Header="Edit Supported Extensions..."
                          ToolTip="Edit the list of recognized ROM file extensions">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/images/settings.png" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Theme" ToolTip="Customize the application appearance">
                <MenuItem Header="Base Theme" ToolTip="Switch between light and dark themes">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/images/theme.png" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem x:Name="LightTheme" Header="Light" Click="ChangeBaseTheme_Click" IsCheckable="True"
                              ToolTip="Switch to light theme" />
                    <MenuItem x:Name="DarkTheme" Header="Dark" Click="ChangeBaseTheme_Click" IsCheckable="True"
                              ToolTip="Switch to dark theme" />
                </MenuItem>
                <MenuItem x:Name="MenuAccentColors" Header="Accent Colors" ToolTip="Choose the accent color for the application">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/images/theme.png" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem x:Name="RedAccent" Header="Red" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Red"
                              ToolTip="Set accent color to Red" />
                    <MenuItem x:Name="GreenAccent" Header="Green" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Green"
                              ToolTip="Set accent color to Green" />
                    <MenuItem x:Name="BlueAccent" Header="Blue" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Blue"
                              ToolTip="Set accent color to Blue" />
                    <MenuItem x:Name="PurpleAccent" Header="Purple" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Purple"
                              ToolTip="Set accent color to Purple" />
                    <MenuItem x:Name="OrangeAccent" Header="Orange" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Orange"
                              ToolTip="Set accent color to Orange" />
                    <MenuItem x:Name="LimeAccent" Header="Lime" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Lime"
                              ToolTip="Set accent color to Lime" />
                    <MenuItem x:Name="EmeraldAccent" Header="Emerald" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Emerald"
                              ToolTip="Set accent color to Emerald" />
                    <MenuItem x:Name="TealAccent" Header="Teal" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Teal"
                              ToolTip="Set accent color to Teal" />
                    <MenuItem x:Name="CyanAccent" Header="Cyan" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Cyan"
                              ToolTip="Set accent color to Cyan" />
                    <MenuItem x:Name="CobaltAccent" Header="Cobalt" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Cobalt"
                              ToolTip="Set accent color to Cobalt" />
                    <MenuItem x:Name="IndigoAccent" Header="Indigo" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Indigo"
                              ToolTip="Set accent color to Indigo" />
                    <MenuItem x:Name="VioletAccent" Header="Violet" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Violet"
                              ToolTip="Set accent color to Violet" />
                    <MenuItem x:Name="PinkAccent" Header="Pink" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Pink"
                              ToolTip="Set accent color to Pink" />
                    <MenuItem x:Name="MagentaAccent" Header="Magenta" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Magenta"
                              ToolTip="Set accent color to Magenta" />
                    <MenuItem x:Name="CrimsonAccent" Header="Crimson" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Crimson"
                              ToolTip="Set accent color to Crimson" />
                    <MenuItem x:Name="AmberAccent" Header="Amber" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Amber"
                              ToolTip="Set accent color to Amber" />
                    <MenuItem x:Name="YellowAccent" Header="Yellow" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Yellow"
                              ToolTip="Set accent color to Yellow" />
                    <MenuItem x:Name="BrownAccent" Header="Brown" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Brown"
                              ToolTip="Set accent color to Brown" />
                    <MenuItem x:Name="OliveAccent" Header="Olive" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Olive"
                              ToolTip="Set accent color to Olive" />
                    <MenuItem x:Name="SteelAccent" Header="Steel" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Steel"
                              ToolTip="Set accent color to Steel" />
                    <MenuItem x:Name="MauveAccent" Header="Mauve" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Mauve"
                              ToolTip="Set accent color to Mauve" />
                    <MenuItem x:Name="TaupeAccent" Header="Taupe" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Taupe"
                              ToolTip="Set accent color to Taupe" />
                    <MenuItem x:Name="SiennaAccent" Header="Sienna" Click="ChangeAccentColor_Click" IsCheckable="True" Tag="Sienna"
                              ToolTip="Set accent color to Sienna" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Donate" ToolTip="Support the developer with a donation">
                <MenuItem Click="DonateButton_Click" Header="Donate"
                          ToolTip="Open the donation page in your browser">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/images/donate.png" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="About" ToolTip="View application information">
                <MenuItem Click="About_Click" Header="About"
                          ToolTip="Show version and credits information">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/images/about.png" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Exit" ToolTip="Close the application">
                <MenuItem Click="Exit_Click" Header="Exit" InputGestureText="Alt+F4"
                          ToolTip="Close the application">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/images/exit.png" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <Grid Grid.Column="0" Margin="0,0,10,0">


                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Step 1: Input Folders -->
                <GroupBox Grid.Row="0" Header="Select Folders" Margin="0,0,0,10"
                          ToolTip="Specify the folders containing your ROMs and cover images">
                    <StackPanel Margin="5">
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtRomFolder" Grid.Column="0"
                                     controls:TextBoxHelper.Watermark="Path to your ROM folder..."
                                     TextChanged="TxtRomFolder_TextChanged"
                                     LostFocus="TxtRomFolder_LostFocus"
                                     PreviewKeyDown="TxtRomFolder_PreviewKeyDown"
                                     AutomationProperties.Name="ROM Folder Path"
                                     AutomationProperties.HelpText="Enter the path to your ROM files folder"
                                     ToolTip="Enter or browse to the folder containing your ROM files"
                                      />
                            <Button Grid.Column="1" Content="Browse..." Margin="5,0,0,0"
                                    Click="BtnBrowseRomFolder_Click"
                                    AutomationProperties.Name="Browse ROM Folder"
                                    ToolTip="Browse for the ROM folder"
                                     />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtImageFolder" Grid.Column="0"
                                     controls:TextBoxHelper.Watermark="Path to your image folder..."
                                     TextChanged="TxtImageFolder_TextChanged"
                                     LostFocus="TxtImageFolder_LostFocus"
                                     PreviewKeyDown="TxtImageFolder_PreviewKeyDown"
                                     AutomationProperties.Name="Image Folder Path"
                                     AutomationProperties.HelpText="Enter the path to your cover images folder"
                                     ToolTip="Enter or browse to the folder containing your cover images"
                                      />
                            <Button Grid.Column="1" Content="Browse..." Margin="5,0,0,0"
                                    Click="BtnBrowseImageFolder_Click"
                                    AutomationProperties.Name="Browse Image Folder"
                                    ToolTip="Browse for the image folder"
                                     />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Step 2: Missing Covers -->
                <GroupBox Grid.Row="1" Margin="0,0,0,0">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <Label x:Name="LabelMissingRoms" Content="LIST OF MISSING COVERS" Padding="0,0,5,0" 
                                   Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                   ToolTip="ROMs that do not have a matching cover image" />
                        </StackPanel>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Content="Check for Missing Images" x:Name="BtnCheckForMissingImages" Click="BtnCheckForMissingImages_ClickAsync"
                                Margin="5"
                                AutomationProperties.Name="Check for Missing Images"
                                AutomationProperties.HelpText="Press to scan for ROM files without cover images"
                                ToolTip="Scan for ROM files that don't have matching cover images (F5)"
                                IsDefault="True"
                                />

                        <Grid Grid.Row="1">
                            <ListBox x:Name="LstMissingImages"
                                     ItemsSource="{Binding MissingImages}"
                                     SelectionChanged="LstMissingImages_SelectionChangedAsync"
                                     PreviewKeyDown="LstMissingImages_PreviewKeyDown"
                                     DisplayMemberPath="RomName"
                                     BorderThickness="0"
                                     AutomationProperties.Name="Missing Images List"
                                     AutomationProperties.HelpText="List of ROM files without cover images. Press Delete to remove an item."
                                     ToolTip="Select a ROM to find similar cover images. Press Delete to remove an item."
                                      />
                            <controls:ProgressRing IsActive="{Binding IsCheckingMissing}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                        </Grid>

                        <Button Grid.Row="2" x:Name="BtnRemoveSelectedItem" Content="Remove Selected Item from List"
                                Click="BtnRemoveSelectedItem_Click" Margin="5"
                                IsEnabled="{Binding ElementName=LstMissingImages, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}"
                                AutomationProperties.Name="Remove Selected Item"
                                AutomationProperties.HelpText="Remove the selected ROM from the missing list"
                                ToolTip="Remove the selected ROM from the missing covers list"
                                 />
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- RIGHT COLUMN -->
            <GroupBox Grid.Column="1" Header="Image Suggestions"
                      ToolTip="Suggested cover images that match the selected ROM name">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Label x:Name="LblSearchQuery" Grid.Row="0" Margin="5,0,5,5"
                           AutomationProperties.Name="Search Query"
                           AutomationProperties.LiveSetting="Polite"
                           ToolTip="The search query used to find similar images" />

                    <Grid Grid.Row="1">
                        <!-- Image Display -->
                        <ScrollViewer x:Name="ImageScrollViewer" VerticalScrollBarVisibility="Auto"
                                      AutomationProperties.Name="Similar Images Scroll Area"
                                      ToolTip="Browse suggested cover images for the selected ROM">
                            <ItemsControl ItemsSource="{Binding SimilarImages}"
                                          AutomationProperties.Name="Similar Images"
                                          AutomationProperties.HelpText="Images that match the selected ROM name">
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="ImageCellTemplate" />
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Loading Overlay -->
                        <Grid Style="{StaticResource LoadingOverlayGridStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <controls:ProgressRing IsActive="{Binding IsFindingSimilar}" 
                                                       Width="60" Height="60"
                                                       Margin="0,0,0,15" />
                                <TextBlock Text="Please wait ... Loading"
                                           Style="{StaticResource LoadingTextStyle}"
                                           AutomationProperties.Name="Loading"
                                           AutomationProperties.LiveSetting="Assertive" />
                            </StackPanel>
                        </Grid>

                        <!-- Empty State Overlay -->
                        <Grid Style="{StaticResource EmptyStateOverlayGridStyle}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                <!-- Message when no item is selected (no search has been performed) -->
                                <TextBlock Text="Select a missing cover from the list to see suggestions."
                                           Style="{StaticResource EmptyStateHintTextStyle}" />

                                <!-- Message when search returned no results (threshold too high) -->
                                <StackPanel HorizontalAlignment="Center"
                                            Style="{StaticResource NoResultsStackPanelStyle}">
                                    <TextBlock Text="No similar images found"
                                               Style="{StaticResource NoResultsTitleTextStyle}" />
                                    <TextBlock Text="No images matched the current similarity threshold."
                                               Style="{StaticResource NoResultsMessageTextStyle}" />
                                    <TextBlock Text="Try lowering the threshold in the menu to see more results."
                                               Style="{StaticResource NoResultsHintTextStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</controls:MetroWindow>
