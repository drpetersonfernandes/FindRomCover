<controls:MetroWindow x:Class="FindRomCover.SettingsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      mc:Ignorable="d"
                      Title="Edit Supported Extensions" Height="450" Width="400"
                      WindowStartupLocation="CenterScreen"
                      ResizeMode="NoResize"
                      ToolTip="Manage which ROM file extensions the application will scan for">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                   ToolTip="Instructions for managing ROM file extensions">
            Manage the list of supported ROM file extensions.
        </TextBlock>

        <ListBox Grid.Row="1"
                 x:Name="LstSupportedExtensions"
                 BorderBrush="{DynamicResource ListBoxBorderBrush}"
                 BorderThickness="1"
                 ItemsSource="{Binding SupportedExtensions}"
                 ToolTip="List of ROM file extensions currently supported. Select an extension to remove it." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button x:Name="BtnAdd" Content="Add..." Width="100" Margin="0,0,10,0" Click="BtnAdd_ClickAsync"
                    ToolTip="Add a new ROM file extension to the supported list" />
            <Button x:Name="BtnRemove" Content="Remove" Width="100" Click="BtnRemove_Click"
                    IsEnabled="{Binding ElementName=LstSupportedExtensions, Path=SelectedItem, Converter={StaticResource IsNotNullConverter}}"
                    ToolTip="Remove the selected extension from the supported list" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="Save" Width="100" Margin="0,0,10,0" Click="BtnSave_Click" IsDefault="True"
                    ToolTip="Save changes to the supported extensions list" />
            <Button x:Name="BtnCancel" Content="Cancel" Width="100" IsCancel="True" Click="BtnCancel_Click"
                    ToolTip="Discard changes and close this window" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
